extends Node
## EventBus
##
## ناقل إشارات عام (Global Signal Bus) — يمثل قناة التواصل المركزية بين كل
## أنظمة اللعبة (الواجهة، إدارة الحفظ، الصوت، ولاحقًا نظام الإيكولوجي والتقدّم).
##
## لماذا هذا النمط؟
## بدلاً من أن يعرف كل نظام تفاصيل الأنظمة الأخرى ويستدعيها مباشرة (ما يؤدي
## إلى ترابط شديد Tight Coupling يصعب صيانته)، تُصدر الأنظمة إشارات هنا،
## وأي نظام آخر مهتم يشترك فيها دون أن يعرف مصدرها. هذا يجعل إضافة أنظمة
## جديدة لاحقًا (اقتصاد اللعبة، الأحداث الموسمية، التفاعل الاجتماعي...) لا
## يتطلب تعديل الكود القديم — فقط الاشتراك في الإشارة المناسبة.
##
## القاعدة: أي إشارة تهم أكثر من نظام واحد تمر من هنا. الإشارات الخاصة
## بمكوّن واجهة داخلي واحد (مثل ضغط زر داخل نفس المشهد) تبقى محلية.

# -- دورة حياة التطبيق والمشهد --------------------------------------------

## يصدر عند تغيّر حالة الإيقاف المؤقت (فتح قائمة، دخول التطبيق للخلفية...).
signal game_pause_state_changed(is_paused: bool)

## يصدر قبل بدء الانتقال البصري إلى مشهد جديد.
signal scene_transition_started(scene_path: String)

## يصدر بعد اكتمال تحميل المشهد الجديد وظهوره بالكامل.
signal scene_transition_finished(scene_path: String)

# -- الحفظ والتحميل ---------------------------------------------------------

signal save_started()
signal save_completed()
signal save_failed(reason: String)
signal load_completed()
signal load_failed(reason: String)

# -- الإعدادات والصوت --------------------------------------------------------

## يصدر عند تغيّر أي إعداد (صوت، جودة رسومية، لغة) ليتسنى لكل نظام تحديث
## نفسه فورًا دون انتظار إعادة تشغيل اللعبة.
signal settings_changed(setting_key: String, new_value: Variant)

signal audio_bus_volume_changed(bus_name: String, linear_volume: float)
