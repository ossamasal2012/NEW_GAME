; Engine configuration file.
; هذا الملف يُدار عادة من داخل محرر Godot، لكنه نص عادي بالكامل ويمكن
; تعديله يدويًا بأمان. راجع docs/ARCHITECTURE.md لشرح كل قرار هنا.

config_version=5

[application]

config/name="فانوس"
config/description="عالم حيّ ينبض داخل فانوس سحري — ينمو معك، ولا ينتهي أبدًا."
run/main_scene="res://scenes/boot/boot.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="res://audio/bus_layout.tres"

[autoload]

EventBus="*res://scripts/autoload/event_bus.gd"
GameManager="*res://scripts/autoload/game_manager.gd"
SceneManager="*res://scripts/autoload/scene_manager.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
SettingsManager="*res://scripts/autoload/settings_manager.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=2340
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="portrait"
window/energy_saving/keep_screen_on=true

[rendering]

renderer/rendering_method="forward_plus"
renderer/rendering_method.mobile="forward_plus"
textures/vram_compression/import_etc2_astc=true
anti_aliasing/quality/msaa_3d=2
anti_aliasing/quality/screen_space_aa=1
environment/defaults/default_clear_color=Color(0.05, 0.04, 0.1, 1)
