# --- Godot 4 --------------------------------------------------------------
# ذاكرة الاستيراد المحلية لمحرر Godot. تُعاد بناؤها تلقائيًا عند فتح
# المشروع أو عبر خطوة "Pre-heat" في GitHub Actions — لا تُحفظ في Git أبدًا.
.godot/
.import/

# ملفات بيانات اعتماد التصدير (كلمات مرور Keystore وغيرها) إن استُخدمت
# لاحقًا؛ يجب أن تبقى محليّة فقط أو تُمرَّر عبر GitHub Secrets.
export_credentials.cfg

# --- مشروع Android المُولَّد ------------------------------------------------
# يُنشئه أمر --install-android-build-template من جديد في كل تشغيل لـ CI،
# لذلك لا حاجة لتتبعه. إن أُضيفت لاحقًا إضافات Android مخصّصة (Play Billing
# مثلًا) تتطلب تعديل هذا المجلد يدويًا، يُعاد النظر في هذا الاستثناء وقتها.
android/

# --- مخرجات البناء ----------------------------------------------------------
build/
*.apk
*.aab

# --- ملفات نظام التشغيل والمحررات ------------------------------------------
.DS_Store
Thumbs.db
*.tmp
*.log
.vscode/
.idea/
